<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="Taknix_studio_links" content="width=device-width, initial-scale=1.0">
  <title>Taknix Studio</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Rajdhani:wght@400;600;700&family=Bebas+Neue&display=swap"
    rel="stylesheet">
  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html,
    body {
      min-height: 100vh;
      width: 100%;
      background: #000;
      overflow-x: hidden;
    }

    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      font-family: 'Rajdhani', sans-serif;
      position: relative;
    }

    .bg-poster {
      position: fixed;
      inset: 0;
      background-size: cover;
      background-position: center top;
      filter: blur(4px) brightness(0.22) saturate(0.65);
      transform: scale(1.06);
      z-index: 0;
    }

    .bg-vignette {
      position: fixed;
      inset: 0;
      z-index: 1;
      background: radial-gradient(ellipse 90% 55% at 50% 0%, rgba(120, 0, 0, 0.28) 0%, transparent 65%), radial-gradient(ellipse 100% 60% at 50% 100%, rgba(0, 0, 0, 0.95) 0%, transparent 75%), radial-gradient(ellipse 100% 100% at 50% 50%, rgba(0, 0, 0, 0.45) 0%, transparent 100%);
    }

    canvas {
      position: fixed;
      inset: 0;
      z-index: 2;
      pointer-events: none;
    }

    .page {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 440px;
      padding: 2.8rem 1.5rem 2.2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .logo-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 2.2rem;
    }

    .logo-img {
      width: 300px;
      max-width: 82vw;
      height: auto;
      filter: drop-shadow(0 0 20px rgba(200, 0, 10, 0.75)) drop-shadow(0 0 50px rgba(180, 0, 0, 0.3));
    }

    .studio-line {
      font-family: 'Cinzel Decorative', serif;
      font-size: 0.52rem;
      font-weight: 700;
      letter-spacing: 0.65em;
      color: rgba(160, 40, 40, 0.52);
      text-transform: uppercase;
      margin-top: 0.35rem;
    }

    .rule {
      width: 100%;
      max-width: 290px;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(180, 0, 0, 0.55) 25%, rgba(220, 0, 10, 1) 50%, rgba(180, 0, 0, 0.55) 75%, transparent);
      margin: 0 0 1.9rem;
      position: relative;
    }

    .rule::after {
      content: '';
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 5px;
      height: 5px;
      background: #c0000a;
      box-shadow: 0 0 8px rgba(200, 0, 0, 0.9);
      clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
    }

    .links {
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
      width: 100%;
    }

    .lcard {
      position: relative;
      display: flex;
      align-items: center;
      gap: 0.95rem;
      padding: 0.88rem 1.15rem;
      border-radius: 6px;
      text-decoration: none;
      color: #ddb8b8;
      overflow: hidden;
      cursor: pointer;
      border: 1px solid rgba(140, 15, 15, 0.3);
      background: rgba(6, 0, 0, 0.38);
      backdrop-filter: blur(18px) brightness(1.1) saturate(1.2);
      -webkit-backdrop-filter: blur(18px) brightness(1.1) saturate(1.2);
      transition: color .3s, transform .15s, border-color .3s, background .3s;
    }

    .lcard::before {
      content: '';
      position: absolute;
      top: 0;
      left: 8%;
      right: 8%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.13), transparent);
      z-index: 5;
      pointer-events: none;
    }

    .lcard::after {
      content: '';
      position: absolute;
      top: 0;
      left: -90%;
      width: 55%;
      height: 100%;
      background: linear-gradient(108deg, transparent 30%, rgba(255, 255, 255, 0.1) 50%, transparent 70%);
      transform: skewX(-18deg);
      transition: left .6s ease;
      z-index: 6;
      pointer-events: none;
    }

    .lcard:hover::after {
      left: 135%;
    }

    .lcard:hover {
      color: #fff;
      border-color: rgba(220, 25, 25, 0.7);
      background: rgba(18, 0, 0, 0.58);
      transform: translateY(-2px);
    }

    .lcard:active {
      transform: scale(0.98);
    }

    .card-bg {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center 25%;
      filter: blur(2px) brightness(0.14) saturate(0.6);
      border-radius: inherit;
      opacity: .75;
      z-index: 0;
      transition: filter .4s, opacity .4s;
    }

    .lcard:hover .card-bg {
      filter: blur(1px) brightness(0.28) saturate(0.85);
      opacity: 1;
    }

    .glass-tint {
      position: absolute;
      inset: 0;
      border-radius: inherit;
      z-index: 1;
      pointer-events: none;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.01) 50%, rgba(255, 255, 255, 0.07) 100%);
      opacity: 0;
      transition: opacity .3s;
    }

    .lcard:hover .glass-tint {
      opacity: 1;
    }

    .card-icon {
      position: relative;
      z-index: 7;
      width: 40px;
      height: 40px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      background: rgba(0, 0, 0, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.07);
    }

    .card-body {
      position: relative;
      z-index: 7;
      flex: 1;
      line-height: 1.25;
    }

    .card-name {
      display: block;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.15rem;
      letter-spacing: 0.18em;
      color: inherit;
    }

    .card-handle {
      display: block;
      font-size: 0.72rem;
      font-weight: 400;
      color: rgba(170, 100, 100, 0.58);
      letter-spacing: 0.05em;
      margin-top: 1px;
    }

    .lcard:hover .card-handle {
      color: rgba(210, 145, 145, 0.82);
    }

    .card-arr {
      position: relative;
      z-index: 7;
      color: rgba(160, 30, 30, 0.5);
      font-size: 1rem;
      font-family: 'Rajdhani', sans-serif;
      transition: transform .25s, color .25s;
    }

    .lcard:hover .card-arr {
      transform: translateX(5px);
      color: #ff6060;
    }

    #website-card {
      border-color: rgba(140, 120, 30, 0.3);
    }

    #website-card:hover {
      border-color: rgba(200, 170, 60, 0.65);
    }

    #website-card .card-name {
      color: #c8a050;
    }

    #website-card:hover .card-name {
      color: #e8c870;
    }

    #wh {
      position: relative;
    }

    .soon-badge {
      display: inline-block;
      background: rgba(180, 140, 30, 0.18);
      border: 1px solid rgba(180, 140, 30, 0.35);
      color: rgba(200, 160, 50, 0.85);
      font-size: 0.58rem;
      letter-spacing: 0.12em;
      padding: 1px 6px;
      border-radius: 3px;
      font-family: 'Rajdhani', sans-serif;
      font-weight: 700;
      text-transform: uppercase;
      margin-left: 6px;
      vertical-align: middle;
    }

    .footer {
      margin-top: 2.4rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      align-items: center;
    }

    .footer-rule {
      width: 120px;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(140, 0, 0, 0.35), transparent);
      margin: 0.3rem 0;
    }

    .footer-quote {
      font-size: 0.64rem;
      letter-spacing: 0.16em;
      color: rgba(110, 35, 35, 0.5);
      text-transform: uppercase;
    }

    .footer-quote em {
      color: rgba(170, 55, 55, 0.72);
      font-style: normal;
    }

    .footer-copy {
      font-family: 'Rajdhani', sans-serif;
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      color: rgba(90, 25, 25, 0.42);
    }
  </style>
</head>

<body>
  <div class="bg-poster" id="bgPoster"></div>
  <div class="bg-vignette"></div>
  <canvas id="c"></canvas>
  <div class="page">
    <div class="logo-wrap">
      <img class="logo-img" id="logoImg" alt="Taknix Studio">
      <span class="studio-line">&middot; &middot; Studio &middot; &middot;</span>
    </div>
    <div class="rule"></div>
    <div class="links">
      <a class="lcard" href="https://youtube.com/@taknix_studio?si=akNgpkb2jV3kLUcV" target="_blank" rel="noopener">
        <div class="card-bg" id="cb1"></div>
        <div class="glass-tint"></div>
        <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="rgba(235,30,30,0.95)">
            <path
              d="M21.8 8s-.2-1.4-.8-2c-.8-.8-1.7-.8-2.1-.9C16.2 5 12 5 12 5s-4.2 0-6.9.1c-.4.1-1.3.1-2.1.9-.6.6-.8 2-.8 2S2 9.6 2 11.2v1.5c0 1.6.2 3.2.2 3.2s.2 1.4.8 2c.8.8 1.9.8 2.3.8C6.8 19 12 19 12 19s4.2 0 6.9-.2c.4-.1 1.3-.1 2.1-.9.6-.6.8-2 .8-2s.2-1.6.2-3.2v-1.5C22 9.6 21.8 8 21.8 8zM9.7 14.8V9.2l5.7 2.8-5.7 2.8z" />
          </svg></div>
        <div class="card-body"><span class="card-name">YouTube</span><span class="card-handle">@taknix_studio</span>
        </div>
        <span class="card-arr">&#8594;</span>
      </a>
      <a class="lcard" href="https://www.instagram.com/takinix?igsh=MXBzdnJ4ZmlwcG03Ng==" target="_blank"
        rel="noopener">
        <div class="card-bg" id="cb2"></div>
        <div class="glass-tint"></div>
        <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"
            stroke="rgba(210,90,210,0.95)" stroke-width="1.8" stroke-linecap="round">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <circle cx="12" cy="12" r="5" />
            <circle cx="17.5" cy="6.5" r="1.3" fill="rgba(210,90,210,0.95)" stroke="none" />
          </svg></div>
        <div class="card-body"><span class="card-name">Instagram</span><span class="card-handle">@takinix</span></div>
        <span class="card-arr">&#8594;</span>
      </a>
      <a class="lcard" id="website-card" href="takinix-universe.html" target="_blank" rel="noopener">
        <div class="card-bg" id="cb4"></div>
        <div class="glass-tint"></div>
        <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"
            stroke="rgba(180,160,80,0.95)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <path
              d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
          </svg></div>
        <div class="card-body"><span class="card-name">Website</span><span class="card-handle"
            id="wh">takinix-universe.html <span class="soon-badge">Soon</span></span></div>
        <span class="card-arr">&#8594;</span>
      </a>
      <a class="lcard" href="https://t.me/Takinix_369" target="_blank" rel="noopener">
        <div class="card-bg" id="cb3"></div>
        <div class="glass-tint"></div>
        <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"
            stroke="rgba(60,165,230,0.95)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z" />
          </svg></div>
        <div class="card-body"><span class="card-name">Telegram</span><span class="card-handle">@Takinix_369</span>
        </div>
        <span class="card-arr">&#8594;</span>
      </a>
    </div>
    <div class="footer">
      <div class="footer-rule"></div>
      <p class="footer-quote">Bandage is not weakness &mdash; it&rsquo;s <em>armor for the mind</em></p>
      <p class="footer-copy">&copy; 2025 Taknix Studio &mdash; All Rights Reserved</p>
    </div>
  </div>
  <script>
    const POSTER_DATA = "";
    const LOGO_DATA = "";
    const pu = "url('data:image/jpeg;base64," + POSTER_DATA + "')";
    document.getElementById('bgPoster').style.backgroundImage = pu;
    ['cb1', 'cb2', 'cb3', 'cb4'].forEach(function (id) { document.getElementById(id).style.backgroundImage = pu; });
    document.getElementById('logoImg').src = "data:image/png;base64," + LOGO_DATA;
    const canvas = document.getElementById('c');
    const ctx = canvas.getContext('2d');
    let W, H;
    function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
    resize(); window.addEventListener('resize', resize);
    const pts = [];
    for (var i = 0; i < 70; i++) { pts.push({ x: Math.random() * 1200, y: Math.random() * 800, r: Math.random() * 1.3 + 0.3, vy: -(Math.random() * 0.45 + 0.1), vx: (Math.random() - .5) * 0.22, base: Math.random() * 0.5 + 0.12, f: Math.random() * 6.28, col: Math.random() > .55 ? '200,0,0' : '125,0,0' }); }
    function frame() { ctx.clearRect(0, 0, W, H); pts.forEach(function (p) { p.y += p.vy; p.x += p.vx; p.f += 0.048; if (p.y < -5) { p.y = H + 5; p.x = Math.random() * W; } var a = p.base * (0.65 + 0.35 * Math.sin(p.f)); ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2); ctx.fillStyle = 'rgba(' + p.col + ',' + a + ')'; ctx.fill(); }); requestAnimationFrame(frame); }
    frame();
  </script>
</body>

</html>
